# ─── Auth.js (NextAuth v5) ───────────────────────────────────────────────
# Auth.js v5 auto-detects these variable names.

# A random secret used to encrypt the session JWT. Generate one with:
#   npx auth secret
# or:
#   openssl rand -base64 33
AUTH_SECRET=

# GitHub OAuth App credentials (see README → "Register the GitHub OAuth App").
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Name of the app
NEXT_PUBLIC_APP_NAME=

# Optional: set explicitly if the app is not served from http://localhost:3000
# in development, or behind a proxy in production.
# AUTH_URL=http://localhost:3000
